LEGACYLENS_APP_NAME=LegacyLens API
LEGACYLENS_ENVIRONMENT=dev
LEGACYLENS_API_PREFIX=/api
LEGACYLENS_API_VERSION=0.1.0
LEGACYLENS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:4173"]
LEGACYLENS_QDRANT_URL=<QDRANT_URL>
LEGACYLENS_QDRANT_API_KEY=<QDRANT_API_KEY_IF_ENABLED>
LEGACYLENS_QDRANT_COLLECTION=legacylens_chunks
LEGACYLENS_OPENAI_API_KEY=<OPENAI_API_KEY>
LEGACYLENS_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LEGACYLENS_LANGFUSE_PUBLIC_KEY=<LANGFUSE_PUBLIC_KEY>
LEGACYLENS_LANGFUSE_SECRET_KEY=<LANGFUSE_SECRET_KEY>
LEGACYLENS_EMBEDDING_MODEL=text-embedding-3-small
LEGACYLENS_GENERATION_MODEL=gpt-4.1-mini
LEGACYLENS_LOCAL_EMBEDDING_DIMENSIONS=256
LEGACYLENS_OPENAI_TIMEOUT_SECONDS=120
LEGACYLENS_EMBEDDING_BATCH_SIZE=24
LEGACYLENS_EMBEDDING_MAX_RETRIES=3
LEGACYLENS_EMBEDDING_RETRY_BACKOFF_SECONDS=1.5
LEGACYLENS_QUERY_TOP_K=5
LEGACYLENS_MAX_CONTEXT_CHARACTERS=9000
LEGACYLENS_SOURCE_DIRECTORIES=["data/corpus/sourceforge-trunk"]
LEGACYLENS_SOURCE_EXTENSIONS=[]
LEGACYLENS_CHUNK_MAX_LINES=80
LEGACYLENS_CHUNK_OVERLAP_LINES=16
LEGACYLENS_SOURCEFORGE_SYNC_TIMEOUT_SECONDS=120
