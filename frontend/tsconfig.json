{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "typeRoots": ["node_modules/@types"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
    ,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
